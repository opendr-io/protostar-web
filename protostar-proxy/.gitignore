# The plugin-enabled binary is machine-specific — rebuild via build-proxy.py
caddy.exe
caddy
# OWASP CRS ruleset — fetched by build-proxy.py (pinned version), not vendored
coreruleset-4.28.0/
# Caddy runtime state
*.log
autosave.json
# transient stdout/stderr when caddy is launched with redirected output
*.out
*.err
# self-signed TLS cert/key (regenerate per host)
tls-cert.pem
tls-key.pem
coraza-audit.log
# caddy-security local-account credential(s) (generated by start-proxy.py on first run) — never commit
local-users.conf
# caddy-security's own runtime-managed local user store (derived from local-users.conf) — never commit
local-users.json
# Google OAuth2 client ID/secret for the perimeter portal (from Google Cloud Console) — never commit
google-oauth-client.conf
# per-deployment email allowlist for Google SSO through the perimeter gate — never commit
google-allowlist.conf
# derived Google provider/enable snippets (regenerated each run by start-proxy.py) — never commit
google-provider.conf
google-enable.conf
# perimeter session/JWT signing key (generated by start-proxy.py on first run) — never commit
security-jwt-key.conf
