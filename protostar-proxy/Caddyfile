# protostar-proxy -- reverse proxy fronting React, Flask, protostar-neo, Neo4j.
# See docs/reverse-proxy-design.md. Run via start-proxy.py (sets the env vars below).
#
# Toggles (env, flipped with `caddy reload`):
#   CORAZA_MODE       On | DetectionOnly | Off
#   RATELIMIT_EVENTS  events per window (large number ~= disabled)
#   RATELIMIT_WINDOW  e.g. 60s
#
# Perimeter gate: caddy-security portal at /auth/ (local username/password OR
# "Sign in with Google" - user's choice), enforced via `authorize with gatepolicy`
# on every route. This is a COOKIE-based session, not the Authorization header,
# so - unlike the old basic_auth - it covers /api and /neo4j too without
# colliding with their own Authorization header (JWT Bearer / Neo4j Basic).
# See design doc section 5.1/13. Credentials/secrets are all gitignored, read via
# env or import - never written into this tracked Caddyfile. start-proxy.py
# prompts for them on first run (local account, JWT signing key, optional Google
# OAuth client, email allowlist) and skips prompts for files that already exist.
{
	# admin API on loopback so `caddy reload` works (needed for the toggles)
	admin localhost:2019
	# don't try to install the internal CA root into the OS trust store (needs
	# admin and blocks on Windows). Clients trust the CA manually or use -k.
	skip_install_trust
	order coraza_waf first
	order rate_limit before basic_auth
	order authenticate before respond
	order authorize before basic_auth

	# --- caddy-security: dual-mode perimeter gate (local user/pass OR Google SSO) ---
	security {
		# Proxy-level credential store, deliberately separate from the app's own
		# Postgres appusers/JWT login (see design doc 5.1: "the gate says you may
		# reach the app; the JWT says who you are").
		local identity store localdb {
			realm local
			path local-users.json
			import local-users.conf
		}

		# Google OAuth2 gives per-user identity for free; WHO is let through is
		# an authorization decision (the allowlist below), not per-user
		# provisioning. The provider block is GENERATED by start-proxy.py into
		# google-provider.conf (or left empty when no Google client is set) --
		# caddy-security rejects an empty client_id, so Google must be omitted
		# entirely when unconfigured, otherwise the whole gate (local auth too)
		# fails to provision. No client secret lives in this tracked file.
		import google-provider.conf

		authentication portal gateportal {
			crypto default token lifetime 86400
			crypto key sign-verify {env.PROTOSTAR_JWT_KEY}
			enable identity store localdb
			# `enable identity provider google` -- generated into google-enable.conf,
			# empty when Google isn't configured (see google-provider.conf note).
			import google-enable.conf
			# Local-store logins always get through; Google logins are gated by
			# the per-deployment email allowlist imported below. The `ui link` adds
			# a clickable app tile to the post-login portal so it launches the app
			# (the portal is otherwise an empty landing page).
			transform user {
				match origin local
				action add role authp/user
				ui link "Protostar" / icon "las la-rocket"
			}
			import google-allowlist.conf
		}

		# CRITICAL: do NOT add `validate bearer header` here -- that opts this
		# policy back into checking the Authorization header and reintroduces
		# the exact JWT-Bearer/Neo4j-Basic collision this gate design avoids.
		authorization policy gatepolicy {
			set auth url /auth/
			crypto key verify {env.PROTOSTAR_JWT_KEY}
			allow roles authp/user
		}
	}
}

# Listens on all interfaces (:port = 0.0.0.0). TLS uses an explicit self-signed
# cert (build-proxy.py generates tls-cert.pem/tls-key.pem with SANs). A bare-port
# site with `tls internal` can't present a cert for the client's SNI, so we pin an
# explicit cert. For a public domain, use the domain as the site address for
# automatic HTTPS instead.
:8443 {
	tls tls-cert.pem tls-key.pem

	# --- Login portal (local + Google) --- handle, not handle_path: preserves
	# the full path so the portal's internal routes (OAuth callback, form
	# action) resolve correctly.
	handle /auth/* {
		authenticate with gateportal
	}

	# --- WAF (Coraza). Mode set by start-proxy.py (On | DetectionOnly | Off). ---
	# Loaded in DetectionOnly first so CRS false positives are logged, not blocked.
	# Audit log (coraza-audit.log) records every rule that fires: id, msg, match.
	coraza_waf {
		directives `
			SecRuleEngine On
			SecRequestBodyAccess On
			SecRequestBodyLimit 13107200
			SecResponseBodyAccess Off
			SecAuditEngine RelevantOnly
			SecAuditLog coraza-audit.log
			SecAuditLogParts ABCFHZ
			SecAction "id:990,phase:1,pass,nolog,ctl:forceRequestBodyVariable=On"

			# --- OWASP Core Rule Set 4.28.0 ---
			Include coreruleset-4.28.0/crs-setup.conf
			Include coreruleset-4.28.0/rules/*.conf

			# --- local WAF exceptions / tuning (route-scoped CRS exclusions) ---
			Include waf-exceptions.conf

			# --- custom Neo4j hard-blocks (independent of CRS anomaly scoring) ---
			# Stopgap virtual patch + tripwire on the browser Cypher channel. The neo app
			# only ever sends MATCH/RETURN/WHERE/WITH/LIMIT, so blocking writes, procedures
			# (CALL/apoc), admin/DDL, and system-db access here is ~false-positive-free.
			# t:jsDecode decodes \uXXXX / \xHH first, so JSON-unicode evasion (e.g. a body
			# with "CREATE") can't smuggle a keyword past the regex. NOT a real fix:
			# reads (exfiltration) still pass. Durable controls = a read-only Neo4j user
			# and moving Cypher server-side (see docs/reverse-proxy-design.md §9).
			SecRule REQUEST_URI "@beginsWith /neo4j" "id:1000,phase:2,deny,status:403,msg:'Cypher write/DDL/admin/procedure blocked at proxy',chain"
				SecRule REQUEST_BODY "@rx (?i)\b(create|merge|set|delete|detach|remove|drop|call|foreach|load\s+csv|alter|grant|revoke|deny)\b" "t:jsDecode"
			SecRule REQUEST_URI "@beginsWith /neo4j" "id:1001,phase:2,deny,status:403,msg:'Unbounded Cypher traversal blocked at proxy',chain"
				SecRule REQUEST_BODY "@rx \*\d*(\.\.)?\]" "t:jsDecode"
			SecRule REQUEST_URI "@rx (?i)/neo4j.*(system|\.\.|%2e)" "id:1003,phase:1,deny,status:403,msg:'Neo4j system-db / path traversal blocked at proxy'"
		`
	}

	# --- Rate limiting (events/window from env; large events ~= disabled) ---
	rate_limit {
		zone protostar {
			key {remote_host}
			events 1000
			window 60s
		}
	}

	# --- Flask API (gated: cookie session, doesn't collide with the app's own
	# JWT Bearer header) ---
	# Allowlisted: only the endpoints below are proxied; anything else 403s at the
	# proxy (notably /renew and /register). New Flask endpoints must be added here.
	handle_path /api/* {
		authorize with gatepolicy
		@app path /login /logout /askllm /asklocalllm /setlocallmuse /caniuselocalllm /retrievesummary /getrawalerts /getentities /getentitiesneo /entitydetails /entitydetailsv2 /rawentitydetails /entitydetailsneo /rawentitydetailsneo /retrievecolumnnames /showgraph /apilog /corazalog /connectionstatus /getusers /getallentities /createcase /postcasecomment /loadcasecomments /closecase /getentitytypes /createcasesforallentities /setaicommenting /getaicommenting /searchalerts /savealertexplanation /getalertexplanations /getallcases
		handle @app {
			reverse_proxy 127.0.0.1:5002
		}
		handle {
			respond 403
		}
	}

	# --- Neo4j (gated: cookie session, doesn't collide with the app's own
	# Basic auth header) ---
	handle_path /neo4j/* {
		authorize with gatepolicy
		rewrite * /db/neo4j{uri}
		reverse_proxy 127.0.0.1:7474
	}

	# --- protostar-neo static SPA under /graph ---
	handle_path /graph/* {
		authorize with gatepolicy
		root * ../protostar-neo/dist
		try_files {path} /index.html
		file_server
	}

	# --- React SPA at root ---
	handle {
		authorize with gatepolicy
		root * ../protostar-react/dist
		try_files {path} /index.html
		file_server
	}
}



