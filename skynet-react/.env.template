# Copy this file to .env (same directory) and set your server hostname.
# .env is gitignored. NOTE: Vite bakes these into the JS bundle at build
# time - rebuild after changing.
# Use http://localhost for single-machine use, or http://your-hostname
# (no brackets!) to serve across the network.
VITE_REACT_APP_API_URL=http://localhost
VITE_REACT_APP_API_PORT=5002

# Disable ESLint completely
VITE_DISABLE_ESLINT=true
